# Copy to `.env` and fill in. Never commit the real .env.
# Spaces access key pair (DO console -> API -> Spaces Keys -> Generate New Key)
SPACES_KEY=xxxxxxxxxxxxxxxxxxxx
SPACES_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Your Space region + name, e.g. fra1 / boda-fotos
SPACES_REGION=fra1
SPACES_BUCKET=boda-fotos

# Derived endpoints (keep these patterns, just swap region/bucket)
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
CDN_BASE=https://boda-fotos.fra1.cdn.digitaloceanspaces.com

# Long random string; required in the x-admin-token header to moderate.
ADMIN_TOKEN=change-me-to-a-long-random-string

# The site origin allowed to call these functions (CORS). Use your real domain.
# For local dev you can temporarily set http://localhost:5173
ALLOWED_ORIGIN=https://tu-boda.ondigitalocean.app

# Sightengine AI moderation (dashboard -> API credentials)
SIGHTENGINE_USER=1234567890
SIGHTENGINE_SECRET=abcdefgh_sightengine_secret

# Moderation thresholds (0..1). Tuned to avoid wedding false positives:
#  - explicit/gore/weapon/offensive >= MOD_HIGH  -> auto-REJECT (moved to rejected/)
#  - all scores < MOD_LOW and suggestive < MOD_SUGG -> auto-APPROVE (public)
#  - anything in between -> left in pending/ for MANUAL review
MOD_HIGH=0.8
MOD_LOW=0.4
MOD_SUGG=0.8
